{
    "name": "@fozy-labs/simplest-di",
    "version": "0.2.2",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "type": "module",
    "prettier": "@fozy-labs/js-configs/prettier",
    "scripts": {
        "build": "rimraf ./dist && tsc && tsc-alias --excludePaths react",
        "build:watch": "npm run build && (concurrently \"tsc -w\" \"tsc-alias -w --excludePaths react\")",
        "ts-check": "tsc --noEmit",
        "test": "tsc -p tsconfig.test.json && vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "format": "prettier --write src/",
        "format:check": "prettier --check src/",
        "check:all": "npm run lint && npm run ts-check && npm run test && npm run format:check"
    },
    "devDependencies": {
        "@fozy-labs/js-configs": "^0.1.3",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^22.0.0",
        "@types/react": "^19.2.14",
        "@vitest/coverage-v8": "^4.0.18",
        "concurrently": "9.2.0",
        "eslint": "^9.20.0",
        "jiti": "^2.4.0",
        "jsdom": "^28.1.0",
        "prettier": "^3.5.0",
        "react": "^19.0.0",
        "rimraf": "6.1.2",
        "rxjs": "^7.0.0",
        "tsc-alias": "^1.8.16",
        "tsconfig-paths": "4.2.0",
        "typescript": "5.9.2",
        "vitest": "^4.0.18"
    },
    "peerDependencies": {
        "rxjs": "^7.0.0",
        "react": "^19.0.0"
    },
    "peerDependenciesMeta": {
        "react": {
            "optional": true
        }
    },
    "description": "Простейшая система внедрения зависимостей для React-приложений с поддержкой RxJS.",
    "author": "Vladimir Panev <vova6255@gmail.com>",
    "homepage": "https://github.com/fozy-labs/simplest-di",
    "license": "MIT",
    "keywords": [
        "dependency-injection",
        "di",
        "react",
        "rxjs",
        "ioc",
        "singleton",
        "transient",
        "scoped"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/fozy-labs/simplest-di.git"
    },
    "bugs": {
        "url": "https://github.com/fozy-labs/simplest-di/issues"
    },
    "files": [
        "dist",
        "docs",
        "README.md",
        "LICENSE"
    ],
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "sideEffects": false,
    "publishConfig": {
        "access": "public"
    }
}
